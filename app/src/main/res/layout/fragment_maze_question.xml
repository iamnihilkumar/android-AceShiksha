<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@color/white">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="#1B5E20"
        android:textStyle="bold"
        android:text="ANSWER TO MOVE FORWARD"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/tvSheetQuestion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_primary"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="16dp"
        android:text="Question text here" />

    <Button
        android:id="@+id/btnSheetA"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#E8F5E9"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="14dp"
        android:text="A. " />

    <Button
        android:id="@+id/btnSheetB"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#E8F5E9"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="14dp"
        android:text="B. " />

    <Button
        android:id="@+id/btnSheetC"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="8dp"
        android:backgroundTint="#E8F5E9"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="14dp"
        android:text="C. " />

    <Button
        android:id="@+id/btnSheetD"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:backgroundTint="#E8F5E9"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="14dp"
        android:text="D. " />

    <TextView
        android:id="@+id/tvSheetFeedback"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textSize="14sp"
        android:gravity="center"
        android:textStyle="bold"
        android:visibility="gone"
        android:text="" />

</LinearLayout>