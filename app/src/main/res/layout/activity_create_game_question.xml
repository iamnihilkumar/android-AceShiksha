<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/green_dark"
            android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar" />

        <!-- Question Counter Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/green_dark"
            app:cardCornerRadius="8dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Questions Added"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvQuestionCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Session Settings (Game Type, Class, Subject) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SESSION SETTINGS"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Game Type"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <Spinner
                    android:id="@+id/spinnerGameType"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp" />

                <!-- ✅ NEW: Hint card shown only for Memory Match and True or False -->
                <TextView
                    android:id="@+id/tvGameTypeHint"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="10dp"
                    android:background="#FFF8E1"
                    android:padding="12dp"
                    android:textSize="13sp"
                    android:textColor="#5D4037"
                    android:lineSpacingExtra="3dp"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Class Level"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <Spinner
                    android:id="@+id/spinnerClassLevel"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Subject"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <EditText
                    android:id="@+id/etSubject"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="e.g. Science"
                    android:paddingHorizontal="12dp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Question Details -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QUESTION DETAILS"
            android:textSize="11sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="4dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Question"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <EditText
                    android:id="@+id/etQuestion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="80dp"
                    android:gravity="top"
                    android:background="@drawable/bg_input_field"
                    android:hint="Enter your question"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="8dp"
                    android:inputType="textMultiLine"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Option A"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <EditText
                    android:id="@+id/etOptionA"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Enter Option A"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Option B"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <EditText
                    android:id="@+id/etOptionB"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Enter Option B"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Option C"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <EditText
                    android:id="@+id/etOptionC"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Enter Option C"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Option D"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <EditText
                    android:id="@+id/etOptionD"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Enter Option D"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="12dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="10dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Correct Answer"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

                <Spinner
                    android:id="@+id/spinnerCorrectAnswer"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_field"
                    android:layout_marginTop="4dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Buttons -->
        <Button
            android:id="@+id/btnAddNextQuestion"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#1565C0"
            android:text="+ Add Next Question"
            android:textColor="@color/white"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnDone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="32dp"
            android:backgroundTint="@color/green_dark"
            android:text="✓ Done (Save &amp; Finish)"
            android:textColor="@color/white"
            android:textSize="15sp" />

    </LinearLayout>

</ScrollView>
