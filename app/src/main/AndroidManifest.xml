<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

<uses-permission android:name="android.permission.INTERNET" />
<uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

<application
    android:allowBackup="true"
    android:dataExtractionRules="@xml/data_extraction_rules"
    android:fullBackupContent="@xml/backup_rules"
    android:icon="@mipmap/ic_launcher"
    android:label="@string/app_name"
    android:roundIcon="@mipmap/ic_launcher_round"
    android:supportsRtl="true"
    android:theme="@style/Theme.EduReach1">

    <activity
        android:name=".activities.SplashActivity"
        android:theme="@style/Theme.EduReach1.Splash"
        android:exported="true">
        <intent-filter>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent-filter>
    </activity>

    <activity
        android:name=".activities.LoginActivity"
        android:exported="false" />

    <activity
        android:name=".activities.RegisterActivity"
        android:exported="false" />

    <activity
        android:name=".activities.MainActivity"
        android:exported="false"
        android:windowSoftInputMode="adjustResize"/>

    <activity
        android:name=".activities.CreateQuizActivity"
        android:label="Create Quiz"
        android:exported="false"/>

    <activity android:name=".activities.QuizAttemptActivity"
        android:exported="false"/>

    <activity android:name=".activities.QuizResultActivity"
        android:exported="false"/>

    <activity android:name=".activities.TeacherDashboardActivity"
        android:exported="false"/>

    <activity android:name=".activities.SettingsActivity"
        android:exported="false"/>

    <activity android:name=".activities.PrivacyPolicyActivity"
        android:exported="false"/>


    <activity android:name=".activities.CreateGameQuestionActivity"
        android:exported="false"/>

    <activity android:name=".activities.MazeGameActivity"
        android:exported="false"/>

    <activity android:name=".activities.CarRaceActivity"
        android:exported="false"/>

    <activity android:name=".activities.QuizBattleActivity"
        android:exported="false"/>

    <activity android:name=".activities.GameResultActivity"
        android:exported="false"/>

    <activity android:name=".activities.PdfQuizActivity"
        android:screenOrientation="portrait"
        android:exported="false"/>

    <activity android:name=".activities.StudentReportActivity"
        android:exported="false"/>

    <activity
        android:name=".activities.TeacherStudentListActivity"
        android:exported="false"
        android:screenOrientation="portrait" />

    <activity android:name=".activities.TopicListActivity"
        android:exported="false"/>

    <activity android:name=".activities.TopicFeedbackActivity"
        android:exported="false"
        android:windowSoftInputMode="adjustResize"/>

    <activity android:name=".activities.CreateTopicActivity"
        android:exported="false"
        android:windowSoftInputMode="adjustResize"/>
</application>

</manifest>